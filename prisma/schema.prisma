generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AuthUser {
  id                      String                      @id @default(cuid())
  phoneNumber             String?                     @unique
  email                   String?                     @unique
  passwordHash            String
  isActive                Boolean                     @default(true)
  emailVerified           Boolean                     @default(false)
  phoneVerified           Boolean                     @default(false)
  lastLoginAt             DateTime?
  createdAt               DateTime                    @default(now())
  updatedAt               DateTime                    @updatedAt
  attendanceCorrections   AttendanceCorrection[]      @relation("CorrectedBy")
  attendanceVerifications AttendanceRecord[]          @relation("VerifiedBy")
  createdAuditLogs        AuditLog[]                  @relation("CreatedBy")
  sessions                AuthSession[]
  centerAdmins            CenterAdmin[]
  createdEvents           Event[]                     @relation("EventCreatedBy")
  createdCenters          EventCenter[]               @relation("CenterCreatedBy")
  groupAssignments        GroupAssignment[]           @relation("AssignedBy")
  sentInvites             Invite[]
  members                 Member[]
  otpTokens               OTPToken[]
  passwordResets          PasswordReset[]
  registrations           Registration[]              @relation("RegisteredBy")
  participations          RegistrationParticipation[] @relation("AssignedBy")
  roleAssignments         RoleAssignment[]
  managedAssignments      RoleAssignment[]            @relation("AdminManagesAssignment")

  @@index([phoneNumber])
  @@index([email])
}

model AuthSession {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revoked   Boolean   @default(false)
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  user      AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model OTPToken {
  id          String    @id @default(cuid())
  userId      String?
  code        String
  purpose     String
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int       @default(0)
  createdAt   DateTime  @default(now())
  email       String?
  phoneNumber String?
  user        AuthUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@index([email])
  @@index([code])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model Member {
  id                     String             @id @default(cuid())
  fcsCode                String             @unique
  authUserId             String?
  firstName              String
  lastName               String
  email                  String?
  phoneNumber            String?
  dateOfBirth            DateTime?
  gender                 String?
  maritalStatus          String?
  occupation             String?
  state                  String?
  profilePhotoUrl        String?
  isActive               Boolean            @default(true)
  joinedAt               DateTime           @default(now())
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  branch                 String?
  zone                   String?
  ageBracket             String?
  branchId               String?
  consentTimestamp       DateTime?
  consentVersion         String?
  course                 String?
  department             String?
  emergencyContactName   String?
  emergencyContactPhone  String?
  graduationYear         Int?
  guardianEmail          String?
  guardianName           String?
  guardianPhone          String?
  guardianRelationship   String?
  institutionName        String?
  institutionType        String?
  isMinor                Boolean            @default(false)
  level                  String?
  membershipCategory     String?
  otherNames             String?
  placeOfWork            String?
  preferredContactMethod String?
  preferredName          String?
  privacyPolicyAccepted  Boolean            @default(false)
  signupSource           String             @default("WEB")
  street                 String?
  termsAccepted          Boolean            @default(false)
  whatsappNumber         String?
  yearJoined             Int?
  attendances            AttendanceRecord[]
  createdAuditLogs       AuditLog[]         @relation("AuditMember")
  badges                 Badge[]
  groupAssignments       GroupAssignment[]
  guardianOf             Guardian[]         @relation("IsGuardianOf")
  guardians              Guardian[]         @relation("GuardedBy")
  authUser               AuthUser?          @relation(fields: [authUserId], references: [id])
  unit                   Unit?              @relation("MemberBranch", fields: [branchId], references: [id])
  notifications          Notification[]
  registrations          Registration[]
  roleAssignments        RoleAssignment[]

  @@index([fcsCode])
  @@index([authUserId])
  @@index([phoneNumber])
  @@index([email])
  @@index([branchId])
}

model Guardian {
  id           String   @id @default(cuid())
  memberId     String
  guardianId   String
  relationship String
  createdAt    DateTime @default(now())
  guardian     Member   @relation("IsGuardianOf", fields: [guardianId], references: [id], onDelete: Cascade)
  member       Member   @relation("GuardedBy", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, guardianId])
  @@index([memberId])
  @@index([guardianId])
}

model UnitType {
  id          String   @id @default(cuid())
  name        String   @unique
  level       Int      @unique
  description String?
  createdAt   DateTime @default(now())
  units       Unit[]
}

model Unit {
  id              String           @id @default(cuid())
  unitTypeId      String
  name            String
  code            String           @unique
  description     String?
  parentId        String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  auditLogs       AuditLog[]
  events          Event[]
  areaCenters     EventCenter[]    @relation("AreaCenters")
  stateCenters    EventCenter[]    @relation("StateCenters")
  zoneCenters     EventCenter[]    @relation("ZoneCenters")
  invites         Invite[]
  members         Member[]         @relation("MemberBranch")
  roleAssignments RoleAssignment[]
  parent          Unit?            @relation("UnitHierarchy", fields: [parentId], references: [id])
  children        Unit[]           @relation("UnitHierarchy")
  unitType        UnitType         @relation(fields: [unitTypeId], references: [id])

  @@unique([unitTypeId, name, parentId])
  @@index([unitTypeId])
  @@index([parentId])
  @@index([code])
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  invites         Invite[]
  roleAssignments RoleAssignment[]
  permissions     Permission[]     @relation("PermissionToRole")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())
  roles       Role[]   @relation("PermissionToRole")
}

model RoleAssignment {
  id             String    @id @default(cuid())
  memberId       String
  roleId         String
  unitId         String?
  assignedBy     String
  assignedAt     DateTime  @default(now())
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  managedBy      String?
  assignedByUser AuthUser  @relation(fields: [assignedBy], references: [id])
  managedByUser  AuthUser? @relation("AdminManagesAssignment", fields: [managedBy], references: [id])
  member         Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  role           Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  unit           Unit?     @relation(fields: [unitId], references: [id])

  @@unique([memberId, roleId, unitId])
  @@index([memberId])
  @@index([roleId])
  @@index([unitId])
  @@index([managedBy])
}

model Event {
  id                   String                @id @default(cuid())
  title                String
  description          String?
  unitId               String
  startDate            DateTime
  endDate              DateTime
  registrationStart    DateTime
  registrationEnd      DateTime
  participationMode    String
  isPublished          Boolean               @default(true)
  createdBy            String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  imageUrl             String?
  attendances          AttendanceRecord[]
  auditLogs            AuditLog[]
  badges               Badge[]
  createdByUser        AuthUser              @relation("EventCreatedBy", fields: [createdBy], references: [id])
  unit                 Unit                  @relation(fields: [unitId], references: [id])
  centers              EventCenter[]
  groups               EventGroup[]
  settings             EventSetting?
  notifications        Notification[]
  notificationTriggers NotificationTrigger[]
  registrations        Registration[]

  @@index([unitId])
  @@index([participationMode])
  @@index([createdBy])
}

model EventSetting {
  id                          String   @id @default(cuid())
  eventId                     String   @unique
  requireGroupAssignment      Boolean  @default(false)
  allowSelfRegistration       Boolean  @default(true)
  allowThirdPartyRegistration Boolean  @default(true)
  requireParentalConsent      Boolean  @default(false)
  groupAssignmentMethod       String?
  updatedAt                   DateTime @updatedAt
  event                       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model EventCenter {
  id             String                      @id @default(cuid())
  eventId        String
  centerName     String
  country        String                      @default("Nigeria")
  stateId        String?
  areaId         String?
  zoneId         String?
  address        String
  isActive       Boolean                     @default(true)
  createdBy      String
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  attendances    AttendanceRecord[]
  admins         CenterAdmin[]
  area           Unit?                       @relation("AreaCenters", fields: [areaId], references: [id])
  createdByUser  AuthUser                    @relation("CenterCreatedBy", fields: [createdBy], references: [id])
  event          Event                       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  state          Unit?                       @relation("StateCenters", fields: [stateId], references: [id])
  zone           Unit?                       @relation("ZoneCenters", fields: [zoneId], references: [id])
  registrations  Registration[]              @relation("RegisteredCenter")
  participations RegistrationParticipation[]

  @@index([eventId])
  @@index([stateId])
  @@index([areaId])
  @@index([zoneId])
}

model CenterAdmin {
  id         String      @id @default(cuid())
  centerId   String
  userId     String
  role       String      @default("CENTER_ADMIN")
  assignedAt DateTime    @default(now())
  center     EventCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user       AuthUser    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([centerId, userId])
  @@index([centerId])
}

model Registration {
  id                 String                     @id @default(cuid())
  eventId            String
  memberId           String
  centerId           String?
  registeredBy       String
  registrationDate   DateTime                   @default(now())
  status             String                     @default("CONFIRMED")
  cancellationReason String?
  cancelledAt        DateTime?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  attendanceIntent   String?                    @default("CONFIRMED")
  attendance         AttendanceRecord?
  auditLogs          AuditLog[]                 @relation("RegistrationAudit")
  groupAssignments   GroupAssignment[]
  center             EventCenter?               @relation("RegisteredCenter", fields: [centerId], references: [id])
  event              Event                      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member             Member                     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  registeredByUser   AuthUser                   @relation("RegisteredBy", fields: [registeredBy], references: [id])
  participation      RegistrationParticipation?

  @@unique([eventId, memberId])
  @@index([eventId])
  @@index([memberId])
  @@index([centerId])
  @@index([status])
}

model RegistrationParticipation {
  id                String       @id @default(cuid())
  registrationId    String       @unique
  participationMode String
  centerId          String?
  assignedBy        String
  assignedAt        DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  assignedByUser    AuthUser     @relation("AssignedBy", fields: [assignedBy], references: [id])
  center            EventCenter? @relation(fields: [centerId], references: [id])
  registration      Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@index([registrationId])
  @@index([centerId])
}

model EventGroup {
  id          String            @id @default(cuid())
  eventId     String
  name        String
  description String?
  type        String
  isMandatory Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  event       Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignments GroupAssignment[]

  @@unique([eventId, name])
  @@index([eventId])
}

model GroupAssignment {
  id             String       @id @default(cuid())
  groupId        String
  registrationId String
  memberId       String
  assignedBy     String
  assignedAt     DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  assignedByUser AuthUser     @relation("AssignedBy", fields: [assignedBy], references: [id])
  group          EventGroup   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  member         Member       @relation(fields: [memberId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)

  @@unique([registrationId, groupId])
  @@index([groupId])
  @@index([registrationId])
  @@index([memberId])
}

model AttendanceRecord {
  id                String                 @id @default(cuid())
  eventId           String
  registrationId    String                 @unique
  memberId          String
  centerId          String?
  participationMode String
  checkInMethod     String
  checkInTime       DateTime
  checkOutTime      DateTime?
  verifiedBy        String?
  isVerified        Boolean                @default(false)
  notes             String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  corrections       AttendanceCorrection[]
  center            EventCenter?           @relation(fields: [centerId], references: [id])
  event             Event                  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member            Member                 @relation(fields: [memberId], references: [id], onDelete: Cascade)
  registration      Registration           @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  verifiedByUser    AuthUser?              @relation("VerifiedBy", fields: [verifiedBy], references: [id])

  @@index([eventId])
  @@index([registrationId])
  @@index([memberId])
  @@index([centerId])
  @@index([checkInTime])
}

model AttendanceCorrection {
  id              String           @id @default(cuid())
  attendanceId    String
  correctionType  String
  oldValue        String
  newValue        String
  reason          String
  correctedBy     String
  correctedAt     DateTime         @default(now())
  attendance      AttendanceRecord @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  correctedByUser AuthUser         @relation("CorrectedBy", fields: [correctedBy], references: [id])

  @@index([attendanceId])
}

model AttendanceCode {
  id        String    @id @default(cuid())
  code      String    @unique
  codeType  String
  eventId   String
  expiresAt DateTime
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Badge {
  id                String   @id @default(cuid())
  eventId           String
  memberId          String
  badgeType         String
  badgeUrl          String?
  participationMode String
  centerName        String?
  issuedAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  event             Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member            Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([memberId])
}

model Notification {
  id             String    @id @default(cuid())
  eventId        String?
  recipientEmail String
  recipientPhone String?
  subject        String
  message        String
  sentAt         DateTime?
  deliveredAt    DateTime?
  failureReason  String?
  createdAt      DateTime  @default(now())
  deliveryMethod String
  recipientId    String?
  status         String    @default("PENDING")
  templateData   Json?
  triggerType    String
  event          Event?    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member         Member?   @relation(fields: [recipientId], references: [id])

  @@index([eventId])
  @@index([recipientId])
  @@index([sentAt])
}

model NotificationTrigger {
  id             String   @id @default(cuid())
  eventId        String
  triggerType    String
  deliveryMethod String
  templateId     String?
  recipientType  String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([triggerType])
}

model ReportingView {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  queryName   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AnalyticsSnapshot {
  id                 String   @id @default(cuid())
  eventId            String
  snapshotDate       DateTime
  totalRegistrations Int
  totalAttendance    Int
  onlineAttendance   Int
  onsiteAttendance   Int
  attendanceRate     Float
  createdAt          DateTime @default(now())

  @@unique([eventId, snapshotDate])
  @@index([eventId])
}

model AuditLog {
  id            String       @id @default(cuid())
  entityType    String
  entityId      String
  eventId       String?
  memberId      String?
  unitId        String?
  action        String
  changes       String
  reason        String?
  createdBy     String
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime     @default(now())
  createdByUser AuthUser     @relation("CreatedBy", fields: [createdBy], references: [id])
  registration  Registration @relation("RegistrationAudit", fields: [entityId], references: [id], onDelete: SetNull)
  event         Event?       @relation(fields: [eventId], references: [id])
  member        Member?      @relation("AuditMember", fields: [memberId], references: [id])
  unit          Unit?        @relation(fields: [unitId], references: [id])

  @@index([entityType])
  @@index([eventId])
  @@index([memberId])
  @@index([createdBy])
  @@index([createdAt])
}

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model Invite {
  id            String    @id @default(cuid())
  email         String
  roleId        String
  unitId        String?
  invitedBy     String
  token         String    @unique
  expiresAt     DateTime
  status        String    @default("PENDING")
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  invitedByUser AuthUser  @relation(fields: [invitedBy], references: [id])
  role          Role      @relation(fields: [roleId], references: [id])
  unit          Unit?     @relation(fields: [unitId], references: [id])

  @@index([email])
  @@index([token])
  @@index([invitedBy])
}
